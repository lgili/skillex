{
  "name": "skillex",
  "version": "0.3.1",
  "description": "CLI to list, install, and synchronize AI agent skills from GitHub-hosted catalogs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lgili/skillex.git"
  },
  "homepage": "https://github.com/lgili/skillex#readme",
  "bugs": {
    "url": "https://github.com/lgili/skillex/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "dist-ui",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./fs": {
      "types": "./dist/fs.d.ts",
      "import": "./dist/fs.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./install": {
      "types": "./dist/install.d.ts",
      "import": "./dist/install.js"
    },
    "./sync": {
      "types": "./dist/sync.d.ts",
      "import": "./dist/sync.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "bin": {
    "skillex": "bin/skillex.js"
  },
  "scripts": {
    "build": "npm run build:ui && tsc -p tsconfig.json",
    "build:ui": "vite build --config ui/vite.config.ts",
    "build:test": "tsc -p tsconfig.test.json",
    "typecheck": "npm run typecheck:ui && tsc --noEmit -p tsconfig.json",
    "typecheck:ui": "vue-tsc --noEmit -p ui/tsconfig.app.json",
    "dev:ui": "vite --config ui/vite.config.ts",
    "start": "npm run build && node ./bin/skillex.js",
    "test": "node scripts/check-language.mjs && npm run build:ui && npm run build:test && node --test .test-dist/test/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agent-skills",
    "cli",
    "github",
    "skillex",
    "codex",
    "copilot",
    "cursor"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@types/node": "^24.6.0",
    "@vue/compiler-sfc": "^3.5.13",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "vue-tsc": "^2.2.8"
  },
  "license": "MIT"
}
